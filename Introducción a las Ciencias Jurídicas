.quiz-btn { background: rgb(240, 244, 248); border: 2px solid rgb(221, 227, 234); border-radius: 8px; padding: 0.55rem 0.9rem; text-align: left; cursor: pointer; font-size: 0.88rem; transition: background 0.15s, border-color 0.15s; color: var(--texto); }

.quiz-btn:hover:not(:disabled) { background: var(--azul-claro); border-color: var(--azul); }

