.badge-num { background: var(--azul); color: white; font-size: 0.85rem; font-weight: 700; padding: 0.35rem 0.75rem; border-radius: 999px; white-space: nowrap; }

.menu-toggle { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 200; background: var(--azul); color: white; border: none; border-radius: 50%; width: 52px; height: 52px; font-size: 1.3rem; cursor: pointer; box-shadow: rgba(21, 101, 192, 0.4) 0px 4px 12px; transition: transform 0.2s; }

.menu-toggle:hover { transform: scale(1.1); }

.indice-panel { position: fixed; top: 0px; right: -340px; width: 320px; height: 100%; background: white; z-index: 300; box-shadow: rgba(0, 0, 0, 0.15) -4px 0px 20px; transition: right 0.3s; overflow-y: auto; padding: 1rem; }

.indice-panel.abierto { right: 0px; }

.indice-overlay { display: none; position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.35); z-index: 250; }

.indice-overlay.visible { display: block; }

.indice-titulo { font-weight: 700; font-size: 1rem; margin-bottom: 0.75rem; color: var(--azul); border-bottom: 2px solid var(--azul-claro); padding-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center; }

.btn-cerrar-indice { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--gris); }

.indice-item { display: block; width: 100%; text-align: left; background: none; border: none; padding: 0.45rem 0.6rem; border-radius: 6px; cursor: pointer; font-size: 0.82rem; color: var(--texto); line-height: 1.35; transition: background 0.15s; }

.indice-item:hover { background: var(--azul-claro); }

.indice-item.activo { background: var(--azul); color: white; font-weight: 600; }

.indice-num { font-size: 0.72rem; color: var(--gris); margin-right: 0.4rem; }

.indice-item.activo .indice-num { color: rgba(255, 255, 255, 0.75); }

.indice-item.indice-portada { font-weight: 700; font-size: 0.84rem; color: var(--azul); border-top: 2px solid var(--azul); margin-top: 0.25rem; background: rgba(37, 99, 235, 0.05); }

.indice-item.indice-portada.activo { background: var(--azul); color: white; }

.indice-item.indice-portada { font-weight: 700; font-size: 0.84rem; color: var(--azul); border-top: 2px solid var(--azul); margin-top: 0.3rem; background: none; }

.indice-item.indice-portada.activo { background: var(--azul); color: white; }

.cartilla { display: none; background: var(--tarjeta); padding: 1.5rem 1.6rem; border-radius: 12px; box-shadow: rgba(0, 0, 0, 0.08) 0px 2px 8px; margin-bottom: 1rem; animation: 0.3s ease 0s 1 normal none running fadeIn; }

.cartilla.activa { display: block; }

@keyframes fadeIn { 
  0% { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.cartilla-header { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1rem; border-bottom: 2px solid var(--azul-claro); padding-bottom: 0.75rem; }

.num-cartilla { background: var(--azul); color: white; font-weight: 700; font-size: 0.85rem; padding: 0.3rem 0.65rem; border-radius: 6px; white-space: nowrap; margin-top: 2px; }

.cartilla h2 { margin: 0px; font-size: 1.15rem; color: var(--azul); line-height: 1.3; }

.cita { border-left: 4px solid var(--acento); background: rgb(255, 248, 240); padding: 0.7rem 1rem; margin: 0.9rem 0px; border-radius: 0px 8px 8px 0px; font-style: italic; font-size: 0.93rem; color: rgb(74, 48, 0); }

.cita .autor { display: block; font-style: normal; font-weight: 600; font-size: 0.8rem; color: var(--acento); margin-top: 0.35rem; }

.concepto-clave { background: var(--azul-claro); border: 1px solid rgb(144, 202, 249); border-radius: 8px; padding: 0.75rem 1rem; margin: 0.9rem 0px; font-size: 0.92rem; }

.concepto-clave .etiqueta { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--azul); margin-bottom: 0.25rem; }

.tabla-comp { width: 100%; border-collapse: collapse; margin: 0.9rem 0px; font-size: 0.88rem; }

.tabla-comp th { background: var(--azul); color: white; padding: 0.5rem 0.75rem; text-align: left; }

.tabla-comp td { padding: 0.45rem 0.75rem; border-bottom: 1px solid rgb(229, 231, 235); vertical-align: top; }

.tabla-comp tr:nth-child(2n) td { background: rgb(248, 250, 252); }

.tag { display: inline-block; background: rgb(232, 245, 233); color: rgb(27, 94, 32); border: 1px solid rgb(165, 214, 167); font-size: 0.78rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 999px; margin: 0.1rem 0.15rem; }

.tooltip-wrap { position: relative; display: inline; cursor: help; border-bottom: 1px dashed var(--azul); }

