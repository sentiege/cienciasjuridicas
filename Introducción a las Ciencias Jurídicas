.btn-nav { padding: 0.6rem 1.4rem; border-radius: 8px; border: none; cursor: pointer; font-size: 0.95rem; font-weight: 600; transition: opacity 0.2s, transform 0.1s; }

.btn-nav:active { transform: scale(0.97); }

.btn-prev { background: rgb(224, 231, 239); color: var(--texto); }

.btn-next { background: var(--azul); color: white; }

